# ──────────────────────────────────────────────
# airplex — example environment
# Copy to .env and fill required values before deploying.
# ──────────────────────────────────────────────

# --- Core ---
NODE_ENV=production
APP_URL=https://airplex.example.com
DATABASE_URL=file:/data/airplex.db
LOG_LEVEL=info
TRUST_PROXY=false

# --- Plex (required) ---
PLEX_BASE_URL=https://plex.example.com:32400
PLEX_TOKEN=replace-me-with-plex-server-token
PLEX_CLIENT_IDENTIFIER=airplex

# --- Secrets (required — generate with: openssl rand -hex 32) ---
SESSION_SECRET=
DEVICE_LOCK_SECRET=
SHARE_TOKEN_SECRET=

# --- OIDC (Authentik or any OIDC provider) ---
OIDC_ISSUER_URL=https://auth.example.com/application/o/airplex/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://airplex.example.com/api/auth/callback
OIDC_ADMIN_GROUPS=
OIDC_GROUPS_CLAIM=groups

# --- Share policy ---
SHARE_DEFAULT_TTL_HOURS=48
SHARE_MAX_TTL_HOURS=168
