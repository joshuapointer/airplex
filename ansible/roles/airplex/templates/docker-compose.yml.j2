# docker-compose.yml — generated by Ansible ({{ ansible_date_time.date }})
# DO NOT EDIT BY HAND — changes will be overwritten on the next playbook run.
---
services:
  airplex:
    image: "{{ airplex_image }}"
    restart: unless-stopped
    ports:
      - "{{ airplex_public_port }}:3000"
    env_file:
{% if airplex_env_source == 'sops' %}
      - "{{ airplex_env_file }}"
{% else %}
      - "{{ airplex_install_dir }}/.env"
{% endif %}
    volumes:
      - "{{ airplex_data_dir }}:/data"
    networks:
      - default

{% if airplex_docker_network != 'airplex_default' %}
networks:
  default:
    name: "{{ airplex_docker_network }}"
    external: true
{% endif %}
